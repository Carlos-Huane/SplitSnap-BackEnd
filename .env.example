# Copia este archivo como .env y completa con tus credenciales locales
# El archivo .env está en .gitignore — nunca lo subas al repo

DB_URL=jdbc:mysql://localhost:3306/splitsnap_db?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=America/Lima
DB_USERNAME=root
DB_PASSWORD=TU_PASSWORD_DE_MYSQL

# Ruta absoluta al JSON del service account de Google Cloud (para OCR).
# Crea tu service account en https://console.cloud.google.com/iam-admin/serviceaccounts,
# baja el JSON y guardalo en .gcp/ (carpeta ignorada por git).
GOOGLE_APPLICATION_CREDENTIALS=C:/ruta/absoluta/al/proyecto/SplitSnap-BackEnd/.gcp/splitsnap-vision.json
